# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/stugo

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173

# Google OAuth (get from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# PayOS (https://my.payos.vn)
# Get these from PayOS Dashboard
PAYOS_CLIENT_ID=your-payos-client-id
PAYOS_API_KEY=your-payos-api-key
PAYOS_CHECKSUM_KEY=your-payos-checksum-key

# Email provider (recommended: Brevo on cloud platforms)
# Minimal Brevo setup:
BREVO_API_KEY=your-brevo-smtp-key
BREVO_SMTP_FROM="StuGo <no-reply@yourdomain.com>"

# Optional explicit Brevo SMTP settings (defaults are applied automatically)
# BREVO_SMTP_HOST=smtp-relay.brevo.com
# BREVO_SMTP_PORT=587
# BREVO_SMTP_USER=apikey
# BREVO_SMTP_PASS=your-brevo-smtp-key

# Generic SMTP fallback (if you do not use Brevo)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="StuGo <your-email@gmail.com>"
