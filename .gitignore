stugo-be/.env.local
stugo-be/.env.*.local
stugo-fe/.env
stugo-fe/.env.local
stugo-fe/.env.*.local

# ─────────────────────────────────────────
# Build output
# ─────────────────────────────────────────
stugo-fe/dist/
stugo-fe/dist-ssr/
stugo-be/dist/
stugo-be/build/

